# ─── MongoDB ────────────────────────────────────────────────────────────────────
#
# MONGODB_URI  –  Full connection string (required).
#
#   Standalone (no auth):
#     MONGODB_URI=mongodb://localhost:27017
#
#   Standalone with auth:
#     MONGODB_URI=mongodb://myuser:mypassword@localhost:27017/?authSource=admin
#
#   Replica set:
#     MONGODB_URI=mongodb://host1:27017,host2:27017,host3:27017/?replicaSet=myReplicaSet
#
#   Replica set with auth:
#     MONGODB_URI=mongodb://myuser:mypassword@host1:27017,host2:27017/?replicaSet=myRS&authSource=admin
#
#   MongoDB Atlas (DNS SRV – recommended for Atlas):
#     MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.example.mongodb.net/?retryWrites=true&w=majority
#
#   Self-hosted with TLS:
#     MONGODB_URI=mongodb://myuser:mypassword@host:27017/?tls=true
#     (set MONGODB_TLS_CA_FILE below if the server uses a private/self-signed CA)
#
MONGODB_URI=mongodb://mongo:27017

# Default database shown on startup.
MONGODB_DB=dbv

# ── TLS / Certificate options (all optional) ───────────────────────────────────
#
# Path to a PEM-encoded CA certificate.
# Required when MongoDB uses a certificate signed by a private or self-signed CA.
# Not needed for Atlas or servers using a publicly trusted certificate.
#   MONGODB_TLS_CA_FILE=/run/secrets/mongo-ca.pem
MONGODB_TLS_CA_FILE=

# Path to a PEM file containing the client certificate AND private key.
# Required only for x.509 mutual-TLS client authentication.
#   MONGODB_TLS_CERT_KEY_FILE=/run/secrets/mongo-client.pem
MONGODB_TLS_CERT_KEY_FILE=

# Set to "true" to skip server certificate validation.
# Use ONLY in local development with self-signed certs — never in production.
MONGODB_TLS_ALLOW_INVALID_CERTS=false

# Keycloak realm and client
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=dbv

# Keycloak admin credentials (for initial setup via UI)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Traefik / TLS
# Public hostnames routed by Traefik (add to /etc/hosts for local dev)
DBV_HOST=dbv.localhost
KEYCLOAK_PUBLIC_HOST=keycloak.localhost

# Leave TLS_RESOLVER blank for local self-signed TLS.
# Set to "letsencrypt" in production together with a real ACME_EMAIL.
TLS_RESOLVER=
ACME_EMAIL=admin@example.com

# To enable debug logging, set LOG_LEVEL to "debug" (default is "info").
# RUST_LOG=tower_http=debug
